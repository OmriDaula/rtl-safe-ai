{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["node", "vitest/globals"],
    "noEmit": false,
    "paths": {
      "@rtl-safe-ai/core": ["../packages/core/src/index.ts"]
    }
  },
  "include": ["**/*.ts"],
  "references": [{ "path": "../packages/core" }],
  "exclude": ["dist", "node_modules"]
}
